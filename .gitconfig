[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	clean = git-lfs clean -- %f
	required = true
[user]
	email = 1077309+andreAmorimF@users.noreply.github.com
	name = André Fonseca
	signingkey = DEC232D5B763D8A8
[core]
	editor = nvim
	excludesfile = /Users/andre.fonseca/.gitignore
	attributesfile = /Users/andre.fonseca/.gitattributes
[pull]
	rebase = false
[includeIf "gitdir:/Users/andre.fonseca/Workspace/nubank/"]
	path = /Users/andre.fonseca/.nugitconfig
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[commit]
	gpgsign = true
[gpg]
	program = gpg
